<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 2: Tarefas de hoje + streak — layout compacto, sem emojis, pesos proporcionais -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#1E1E2E">

    <!-- Cabeçalho: streak + pendentes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- 0d"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F38BA8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="|"
            android:textSize="14sp"
            android:textColor="#585B70" />

        <TextView
            android:id="@+id/tv_pending_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0 pendentes"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CBA6F7" />

    </LinearLayout>

    <!-- Divisor sutil (LinearLayout em vez de <View> porque RemoteViews
         não permite a tag <View> pura em layouts de widget) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="#45475A" />

    <!-- Lista de tarefas (até 5 linhas) -->
    <LinearLayout
        android:id="@+id/task_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Linha 1 -->
        <LinearLayout
            android:id="@+id/task_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/task_time_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A6ADC8" />

            <TextView
                android:id="@+id/task_title_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/task_overdue_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="!"
                android:textSize="10sp"
                android:textColor="#F38BA8"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha 2 -->
        <LinearLayout
            android:id="@+id/task_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/task_time_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A6ADC8" />

            <TextView
                android:id="@+id/task_title_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/task_overdue_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="!"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha 3 -->
        <LinearLayout
            android:id="@+id/task_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/task_time_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A6ADC8" />

            <TextView
                android:id="@+id/task_title_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/task_overdue_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="!"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha 4 -->
        <LinearLayout
            android:id="@+id/task_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/task_time_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A6ADC8" />

            <TextView
                android:id="@+id/task_title_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/task_overdue_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="!"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha 5 -->
        <LinearLayout
            android:id="@+id/task_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/task_time_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A6ADC8" />

            <TextView
                android:id="@+id/task_title_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/task_overdue_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="!"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Overflow indicator -->
        <TextView
            android:id="@+id/tv_more"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#585B70"
            android:gravity="end"
            android:paddingTop="2dp" />

        <!-- Estado vazio -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Nenhuma tarefa hoje"
            android:textSize="13sp"
            android:textColor="#585B70" />

    </LinearLayout>

</LinearLayout>